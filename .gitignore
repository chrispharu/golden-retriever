# ==========================================
# Node.js 依賴套件 (絕對不能上傳，體積太大)
# ==========================================
node_modules/

# ==========================================
# 個人資料庫與快取 (🛡️ 保護您的真實庫存與資產隱私！)
# ==========================================
# 假設您的資料存在 db.json 或 data.json，請確保它們被忽略
assets.json
targets.json
watchlist.json
*.json.bak

# ==========================================
# 環境變數與機密金鑰
# ==========================================
.env
.env.local

# ==========================================
# 應用程式日誌檔
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ==========================================
# Electron 打包輸出的資料夾 (未來打包成 exe 時會產生)
# ==========================================
dist/
build/
out/
release/

# ==========================================
# 作業系統與編輯器產生的暫存檔
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/